pc-1311441040.cos.ap-shanghai.myqcloud.com/8ysy8AOcf2RsK43v.png!thumbnail\"></p>\n<p>得到密码：b4ddfa11-4c91-48da-8e57-37d86a3f40ee</p>\n<p>解压压缩包得到1.txt文件，是个mimikatz爆破结果，在里面找到username为flag</p>\n<p>password便是flag</p>\n<p><img src=\"https://nnnpc-1311441040.cos.ap-shanghai.myqcloud.com/vojec67wEkfyZ2AZ.png!thumbnail\"></p>\n","text":"本题的考点在于MQTT协议流量的分析和rsa解密，首先看到流量包 很干净不需要过滤，去了解下MQTT协议能知道 每个包的message字段中存储了需要传输的值，...","permalink":"/post/MQTT","photos":[],"count_time":{"symbolsCount":"4.4k","symbolsTime":"4 mins."},"categories":[{"name":"流量","slug":"流量","count":5,"path":"api/categories/流量.json"}],"tags":[{"name":"流量","slug":"流量","count":5,"path":"api/tags/流量.json"}],"toc":"","author":{"name":"nnnpc","slug":"blog-author","avatar":"/img/2.jpg","link":"/","description":"安全萌新","socials":{"github":"","twitter":"","stackoverflow":"","wechat":"","qq":"","weibo":"","zhihu":"","csdn":"","juejin":"","customs":{}}},"mapped":true,"hidden":false,"prev_post":{"title":"USB","uid":"afb0446e296d7897456eacc683404548","slug":"USB","date":"2023-11-22T19:02:36.409Z","updated":"2023-11-22T19:02:36.410Z","comments":true,"path":"api/articles/USB.json","keywords":null,"cover":"/img/6.jpg","text":"最近做到之前经典的流量题有点多，usb就是其中之一，这里记录一下 首先wireshark打开附件 滑动查看 能发现数据包的HIDData中带有四字节的数据，猜测...","permalink":"/post/USB","photos":[],"count_time":{"symbolsCount":"13k","symbolsTime":"12 mins."},"categories":[{"name":"流量","slug":"流量","count":5,"path":"api/categories/流量.json"}],"tags":[{"name":"流量","slug":"流量","count":5,"path":"api/tags/流量.json"}],"author":{"name":"nnnpc","slug":"blog-author","avatar":"/img/2.jpg","link":"/","description":"安全萌新","socials":{"github":"","twitter":"","stackoverflow":"","wechat":"","qq":"","weibo":"","zhihu":"","csdn":"","juejin":"","customs":{}}}},"next_post":{"title":"冰蝎v3.0流量浅析","uid":"29d4415e6e82777cb6d67446a8f96bd0","slug":"冰蝎v3.0流量浅析","date":"2023-11-22T18:57:51.553Z","updated":"2023-11-22T18:57:51.555Z","comments":true,"path":"api/articles/冰蝎v3.0流量浅析.json","keywords":null,"cover":"/i